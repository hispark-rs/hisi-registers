            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM27 @ 0x98;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM28 @ 0x9C;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM29 @ 0xA0;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM30 @ 0xA4;
    reg {
