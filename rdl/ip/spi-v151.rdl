// Shared HiSilicon SPI v151 register block.
//
// Primary oracle: the byte-identical hal_spi_v151_regs_def.h and register
// operation sources in fbb_ws63 and fbb_bs2x. Chip maps own base addresses,
// instance counts, IRQs, clocks, resets, DMA handshakes and pin routing.

addrmap spi_v151_regs {
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "SPI enable: 0=disabled; 1=enabled";
        } spi_en[0:0] = 0x0;
    } SPI_ER @ 0x0;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Shift register loop test: 0=normal; 1=loopback";
        } soe[0:0] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Shift register loop test control";
        } srlt[1:1] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Slave-select toggle enable";
        } ssn_te[2:2] = 0x0;
        field {
            enum SPI0_SPI_CTRA_scph_e1 {
                FirstEdge = 0 {
                    desc = "Sample on first clock edge";
                };
                SecondEdge = 1 {
                    desc = "Sample on second clock edge";
                };
            } ;
            sw = rw;
            hw = r;
            encode = SPI0_SPI_CTRA_scph_e1;
            desc = "Clock phase: 0=first edge sample; 1=second edge sample";
        } scph[3:3] = 0x0;
        field {
            enum SPI0_SPI_CTRA_scpol_e2 {
                LowIdle = 0 {
                    desc = "SCK idle low";
                };
                HighIdle = 1 {
                    desc = "SCK idle high";
                };
            } ;
            sw = rw;
            hw = r;
            encode = SPI0_SPI_CTRA_scpol_e2;
            desc = "Clock polarity: 0=low idle; 1=high idle";
        } scpol[4:4] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Control frame size in 16-bit transfer mode";
        } cfs16[8:5] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Data frame size in 16-bit transfer mode";
        } dfs16[12:9] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Data frame size in 32-bit mode (0=4bit; up to 31=35bit)";
        } dfs32[17:13] = 0x0;
        field {
            enum SPI0_SPI_CTRA_trsm_e3 {
                TxRx = 0 {
                    desc = "Transmit and Receive";
                };
                TxOnly = 1 {
                    desc = "Transmit Only";
                };
                RxOnly = 2 {
                    desc = "Receive Only";
                };
            } ;
            sw = rw;
            hw = r;
            encode = SPI0_SPI_CTRA_trsm_e3;
            desc = "Transfer mode: 00=TX/RX; 01=TX only; 10=RX only";
        } trsm[19:18] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Enhanced SPI frame format";
        } enhff[21:20] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Serial protocol selection";
        } prs[23:22] = 0x0;
    } SPI_CTRA @ 0x4;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Number of data frames (master TX only mode)";
        } ndf[15:0] = 0x0;
    } SPI_CTRB @ 0x8;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Wait cycles between control and data phases";
        } waitnum[4:0] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Address and instruction transfer format";
        } aaitf[6:5] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Read data strobe enable";
        } rdsen[7:7] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Address phase length selector";
        } addrlen[11:8] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Instruction phase length selector";
        } ilen[13:12] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Instruction DDR enable";
        } iddren[14:14] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Data DDR enable";
        } ddren[15:15] = 0x0;
    } SPI_ENHCTL @ 0xC;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Microwire handshaking enable";
        } mh[0:0] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Microwire sequential transfer mode";
        } mss[1:1] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "Microwire transfer direction";
        } mtrc[2:2] = 0x0;
    } SPI_MCR @ 0x10;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Even clock divider (master): SCK = SSI_CLK / FRDV";
        } frdv[15:0] = 0x0;
    } SPI_BRS @ 0x14;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "TX DMA enable";
        } tden[0:0] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "RX DMA enable";
        } rden[1:1] = 0x0;
    } SPI_DCR @ 0x18;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "DMA RX FIFO threshold";
        } dma_rx_data_level[7:0] = 0x0;
    } SPI_DRDL @ 0x1C;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "DMA TX FIFO threshold";
        } dma_tx_data_level[7:0] = 0x0;
    } SPI_DTDL @ 0x20;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "RX sample delay in SSI clock cycles";
        } rxdsd[7:0] = 0x0;
    } SPI_RSDR @ 0x24;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Transmit data drive edge delay";
        } txdde[7:0] = 0x0;
    } SPI_TDER @ 0x28;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM0 @ 0x2C;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM1 @ 0x30;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM2 @ 0x34;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM3 @ 0x38;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM4 @ 0x3C;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM5 @ 0x40;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM6 @ 0x44;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM7 @ 0x48;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM8 @ 0x4C;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM9 @ 0x50;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM10 @ 0x54;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM11 @ 0x58;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM12 @ 0x5C;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM13 @ 0x60;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM14 @ 0x64;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM15 @ 0x68;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM16 @ 0x6C;
    reg {
