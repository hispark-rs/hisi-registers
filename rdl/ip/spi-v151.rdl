            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM31 @ 0xA8;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM32 @ 0xAC;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM33 @ 0xB0;
    reg {
