            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM34 @ 0xB4;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "Write pushes TX FIFO; read pops RX FIFO";
        } datar[31:0] = 0x0;
    } SPI_DRNM35 @ 0xB8;
    reg {
        field {
            sw = r;
            hw = r;
            desc = "RX FIFO full raw status";
        } rxf_irq[0:0] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "RX FIFO overflow raw status";
        } rxo_irq[1:1] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "RX FIFO underflow raw status";
        } rxu_irq[2:2] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "TX FIFO empty raw status";
        } txe_irq[7:7] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "TX FIFO overflow raw status";
        } txo_irq[8:8] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "Multi-master contention raw status";
        } mst_irq[15:15] = 0x0;
    } SPI_RAINSR @ 0xBC;
    reg {
        field {
            sw = r;
            hw = r;
            desc = "RX full interrupt status";
        } rxf_is[0:0] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "RX overflow interrupt status";
        } rxo_is[1:1] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "RX underflow interrupt status";
        } rxu_is[2:2] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "TX empty interrupt status";
        } txe_is[7:7] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "TX overflow interrupt status";
        } txo_is[8:8] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "Multi-master interrupt status";
        } mst_is[15:15] = 0x0;
    } SPI_INSR @ 0xC0;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "RX full interrupt mask";
        } rxf_im[0:0] = 0x0;
        field {
            sw = rw;
            hw = r;
            desc = "RX overflow interrupt mask";
        } rxo_im[1:1] = 0x0;
        field {
