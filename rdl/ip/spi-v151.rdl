            hw = r;
            desc = "Reading clears the TX FIFO overflow interrupt";
        } cis[0:0] = 0x0;
    } SPI_TFOFICR @ 0xD4;
    reg {
        field {
            sw = rw;
            hw = r;
            desc = "RX FIFO threshold level";
