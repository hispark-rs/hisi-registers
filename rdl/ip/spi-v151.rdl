        field {
            sw = r;
            hw = r;
            desc = "RX FIFO not empty";
        } rxfne[4:4] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "RX FIFO full";
        } rxff[5:5] = 0x0;
        field {
            sw = r;
            hw = r;
            desc = "TX FIFO not full";
        } txfnf[11:11] = 0x1;
        field {
            sw = r;
            hw = r;
            desc = "TX FIFO empty";
        } txfe[12:12] = 0x1;
